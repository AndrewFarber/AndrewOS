folders=(
  "َ°„€ Screenshot"
  "َ°چ¹ Display"
  "َ±‚¬ Workspace"
  "َ°‘“ Refresh"
  "َ°’“ System"
)

declare -A items
items["َ°„€ Screenshot"]="
َ°„€ Screenshot Area|andrewos-screenshot-area
َ°„€ Screenshot Screen|andrewos-screenshot-screen
َ°„€ Screenshot Save to File|andrewos-screenshot-save
"

items["َ°چ¹ Display"]="
َ°چ¹ Change Resolution|andrewos-resolution
َ°¹‘ Change Scale|andrewos-scale
َ°“¼ Rotate Display|andrewos-rotate
َ°¶گ Toggle Display|andrewos-toggle-display
"

items["َ±‚¬ Workspace"]="
َ±‚¬ Move Workspace to Output|andrewos-move-workspace
َ±‚¬ Rename Workspace|andrewos-rename-workspace
"

items["َ°‘“ Refresh"]="
َ°‘“ Refresh Window Manager|andrewos-refresh-wm
َ°‘“ Refresh Waybar|andrewos-refresh-waybar
َ°‘“ Refresh Notifications|andrewos-refresh-swaync
َ°‘“ Refresh Tmux|andrewos-refresh-tmux
َ°œ‰ Restart Pipewire|andrewos-restart-pipewire
َ°œ‰ Restart Wifi|andrewos-restart-wifi
"

items["َ°’“ System"]="
َ±پ¤ Rebuild NixOS|andrewos-rebuild
َ°‡ڑ Update Flake & Rebuild|andrewos-update
َ°©؛ Garbage Collect (User)|andrewos-gc
َ°©؛ Garbage Collect (System)|andrewos-gc-system
َ°”ژ Change Theme|andrewos-theme
َ°¸‰ Change Wallpaper|andrewos-wallpaper
َ°Œ¾ Lock Screen|lock
"

show_folders() {
  local list=""
  for f in "${folders[@]}"; do
    list+="$f"$'\n'
  done
  printf '%s' "$list" | fuzzel --dmenu --prompt "Menu > "
}

search_items() {
  local query="$1"
  local matches=""
  for f in "${folders[@]}"; do
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      local label="${line%%|*}"
      if echo "$label" | grep -qiF "$query"; then
        matches+="$label"$'\n'
      fi
    done <<< "${items[$f]}"
  done
  [ -z "$matches" ] && return 1
  printf '%s' "$matches" | fuzzel --dmenu --prompt "Search > "
}

find_script_any() {
  for f in "${folders[@]}"; do
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      if [ "${line%%|*}" = "$1" ]; then
        echo "${line##*|}"
        return
      fi
    done <<< "${items[$f]}"
  done
}

show_items() {
  local sub="${items[$1]}"
  local display=""
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    display+="${line%%|*}"$'\n'
  done <<< "$sub"
  printf '%s' "$display" | fuzzel --dmenu --prompt "$1 > "
}

find_script() {
  local sub="${items[$1]}"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local label="${line%%|*}"
    local script="${line##*|}"
    if [ "$label" = "$2" ]; then
      echo "$script"
      return
    fi
  done <<< "$sub"
}

# Main loop
while true; do
  rc=0
  choice=$(show_folders) || rc=$?

  # Exit on Escape (1) or Ctrl+H at top level (11)
  [ "$rc" -eq 1 ] && exit 0
  [ "$rc" -eq 11 ] && exit 0
  [ -z "$choice" ] && exit 0

  # If it's a folder, enter sub-menu
  if [ -n "${items[$choice]+x}" ]; then
    while true; do
      rc=0
      pick=$(show_items "$choice") || rc=$?

      # Escape or Ctrl+H: go back to main
      [ "$rc" -eq 1 ] && break
      [ "$rc" -eq 11 ] && break

      # Enter or Ctrl+L: run the selected item
      if [ "$rc" -eq 0 ] || [ "$rc" -eq 10 ]; then
        [ -z "$pick" ] && break
        script=$(find_script "$choice" "$pick")
        [ -n "$script" ] && exec "$script"
      fi

      break
    done
  else
    # Typed text didn't match a folder â€” search all items
    rc=0
    pick=$(search_items "$choice") || rc=$?
    [ "$rc" -eq 1 ] && continue
    [ "$rc" -eq 11 ] && continue
    [ -z "$pick" ] && continue
    script=$(find_script_any "$pick")
    [ -n "$script" ] && exec "$script"
  fi
done
