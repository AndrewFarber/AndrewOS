#!/usr/bin/env bash
BIN_DIR="$(dirname "$(readlink -f "$0")")"

declare -A icons=(
  [launch-terminal]="َ°†چ Open Terminal"
  [launch-browser]="َ°–ں Open Browser"
  [launch-editor]="َ°…ھ Open Editor"
  [launch-files]="َ°‰‹ Open File Manager"
  [launch-git]="َ°ٹ¢ Open Lazygit"
  [launch-docker]="َ°،¨ Open Lazydocker"
  [launch-audio]="َ°•¾ Audio Settings"
  [refresh-wm]="َ°‘“ Refresh Window Manager"
  [refresh-waybar]="َ°‘“ Refresh Waybar Config"
  [refresh-mako]="َ°‘“ Refresh Mako Config"
  [refresh-tmux]="َ°‘“ Refresh Tmux Config"
  [restart-waybar]="َ°œ‰ Restart Waybar"
  [restart-mako]="َ°œ‰ Restart Mako"
  [restart-pipewire]="َ°œ‰ Restart Pipewire"
  [restart-wifi]="َ°œ‰ Restart Wifi"
  [screenshot-area]="َ°„€ Screenshot Area"
  [screenshot-screen]="َ°„€ Screenshot Screen"
  [screenshot-save]="َ°„€ Screenshot Save to File"
  [rebuild]="َ±پ¤ Rebuild NixOS"
  [update]="َ°‡ڑ Update Flake & Rebuild"
  [gc]="َ°©؛ Garbage Collect (User)"
  [gc-system]="َ°©؛ Garbage Collect (System)"
  [lock]="َ°Œ¾ Lock Screen"
)

entries=""
for script in "$BIN_DIR"/*; do
  name=$(basename "$script")
  [ "$name" = "menu" ] && continue
  label="${icons[$name]:-$name}"
  entries+="$label"$'\n'
done

choice=$(printf '%s' "$entries" | fuzzel --dmenu --prompt "> ")
[ -z "$choice" ] && exit 0

# Reverse-lookup: find the script name from the display label
script=""
for key in "${!icons[@]}"; do
  if [ "${icons[$key]}" = "$choice" ]; then
    script="$key"
    break
  fi
done
[ -z "$script" ] && script="$choice"
exec "$BIN_DIR/$script"
