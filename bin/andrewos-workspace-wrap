# Fuzzel launch-prefix wrapper: opens each app on a fixed workspace slot.
# Receives the full exec string from fuzzel as arguments.

cmd="$*"

# When launched via "launch local" keybinding, skip workspace routing
# and open the app on the current workspace.
if [ "${ANDREWOS_LAUNCH_LOCAL:-}" = "1" ]; then
  exec $cmd
fi

# Map command to a fixed app slot (workspace number 11-18).
# More specific patterns first so e.g. claude.ai matches before chromium.
case "$cmd" in
  *github*)       ws_num=12 ;;
  *notion*)       ws_num=13 ;;
  *proton*)       ws_num=14 ;;
  *linear.app*)   ws_num=15 ;;
  *figma*)        ws_num=16 ;;
  *claude.ai*)    ws_num=17 ;;
  *chatgpt*)      ws_num=18 ;;
  *chromium*)     ws_num=11 ;;
  *)
    # Unknown app: find next unused workspace number in 11-18
    used=$(swaymsg -t get_workspaces -r | jq -r '.[].num' | sort -n)
    ws_num=""
    for n in $(seq 11 18); do
      if ! echo "$used" | grep -qx "$n"; then
        ws_num=$n
        break
      fi
    done
    [ -z "$ws_num" ] && ws_num=20
    ;;
esac

# Check if workspace has any windows (not just whether it exists)
has_windows=$(swaymsg -t get_tree | jq '
  [.nodes[].nodes[] | select(.num == '"$ws_num"')] |
  if length == 0 then false
  else .[0] | ((.nodes | length) + (.floating_nodes | length)) > 0
  end
')

if [ "$has_windows" = "true" ]; then
  swaymsg workspace number "$ws_num"
else
  swaymsg workspace "$ws_num"
  exec $cmd
fi
