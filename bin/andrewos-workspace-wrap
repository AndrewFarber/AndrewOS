# Fuzzel launch-prefix wrapper: opens each app on a new named workspace.
# Receives the full exec string from fuzzel as arguments.

cmd="$*"

# Map command to a glyph + label based on patterns in the exec string
case "$cmd" in
  *claude.ai*)    label=$(printf '\U000F09D1 Claude')     ;;
  *chatgpt*)      label=$(printf '\U000F0368 ChatGPT')    ;;
  *figma*)        label=$(printf '\U0000EF47 Figma')      ;;
  *github*)       label=$(printf '\U000F009B GitHub')      ;;
  *linear.app*)   label=$(printf '\U000F0765 Linear')     ;;
  *notion*)       label=$(printf '\U0000E848 Notion')      ;;
  *proton*)       label=$(printf '\U000F0306 Proton Pass') ;;
  *obsidian*)     label=$(printf '\U000F0184 Obsidian')    ;;
  *chromium*)     label=$(printf '\U0000F268 Chromium')    ;;
  *alacritty*)    label=$(printf '\U0000E795 Terminal')    ;;
  *)              label=$(printf '\U000F059F App')         ;;
esac

# Find the lowest unused workspace number (1-20)
used=$(swaymsg -t get_workspaces -r | jq -r '.[].num' | sort -n)
ws_num=1
for n in $used; do
  [ "$n" -eq "$ws_num" ] && ws_num=$((ws_num + 1))
done

# Switch to the new workspace, then exec the app
swaymsg workspace "$ws_num: $label"
exec $cmd
