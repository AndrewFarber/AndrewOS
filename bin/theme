THEMES_DIR="$HOME/AndrewOS/themes"
USER_NIX="$HOME/AndrewOS/user.nix"

if [ ! -f "$USER_NIX" ]; then
  echo "Error: $USER_NIX not found. Copy user.nix.example to user.nix and configure it."
  exit 1
fi

# List theme directories
themes=()
for dir in "$THEMES_DIR"/*/; do
  themes+=("$(basename "$dir")")
done

[ ${#themes[@]} -eq 0 ] && exit 1

# Show picker
chosen=$(printf '%s\n' "${themes[@]}" | fuzzel --dmenu --prompt "Theme > ")
[ -z "$chosen" ] && exit 0

# Read current theme
current=$(sed -n 's/.*theme = "\(.*\)".*/\1/p' "$USER_NIX")

if [ "$chosen" = "$current" ]; then
  exit 0
fi

# Update user.nix
sed -i "s/theme = \".*\"/theme = \"$chosen\"/" "$USER_NIX"

# Rebuild in a floating terminal (so sudo prompt is visible)
# shellcheck disable=SC2016
if ! alacritty --class floating-term -e bash -c 'sudo nixos-rebuild switch --flake ~/AndrewOS; s=$?; echo "Press enter to close..."; read; exit $s'; then
  sed -i "s/theme = \".*\"/theme = \"$current\"/" "$USER_NIX"
  echo "Rebuild failed — reverted to $current"
  exit 1
fi

# Reload WM and restart services with new theme
refresh-wm

systemctl --user restart waybar

swaync-client --reload-config
swaync-client --reload-css

refresh-tmux

echo "Switched to $chosen"
