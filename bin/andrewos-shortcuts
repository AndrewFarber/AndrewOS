shortcuts="
󰘳 Apps
  Super + Return         Terminal
  Super + D              Menu
  Super + Space          App Launcher
  Super + Alt + V        Clipboard History
  Super + Alt + W        Wallpaper Picker

󰌌 Navigation
  Super + H / J / K / L  Focus Left / Down / Up / Right
  Super + 1-0            Switch to Workspace 1-10

󰁌 Layout
  Super + Shift + H/J/K/L  Move Window
  Super + Shift + 1-0      Move to Workspace 1-10
  Super + B                Split Horizontal
  Super + V                Split Vertical
  Super + Shift + Q        Close Window
  Super + R                Resize Mode

󰏗 Scratchpad
  Super + Shift + Minus    Move to Scratchpad
  Super + Minus            Show Scratchpad

󰛐 System
  Super + Shift + S      Screenshot Area
  Super + Shift + C      Reload Config
  Super + Shift + E      Power Menu
  Super + Escape         Lock Screen

󰐊 Media
  Volume Keys            Volume Up / Down / Mute
  Brightness Keys        Brightness Up / Down
  Play / Next / Prev     Media Controls

󰌌 Help
  Super + ?              This Cheatsheet
"

printf '%s' "$shortcuts" | fuzzel --dmenu --prompt "Shortcuts: " --width 70 --lines 25
